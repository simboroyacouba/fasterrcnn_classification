# =============================================================================
# Configuration Faster R-CNN - Détection Toitures Cadastrales
# =============================================================================

# Fichier de classes (partagé avec YOLO)
CLASSES_FILE=classes.yaml

# =============================================================================
# DATASET
# =============================================================================

DETECTION_DATASET_IMAGES_DIR=../dataset1/images/default
DETECTION_DATASET_ANNOTATIONS_FILE=../dataset1/annotations/instances_default.json

# Dossier des images pour inférence
DETECTION_INFERENCE_IMAGES_DIR=../test

# =============================================================================
# ENTRAÎNEMENT
# =============================================================================

NUM_EPOCHS=1
BATCH_SIZE=2
LEARNING_RATE=0.005
MOMENTUM=0.9
WEIGHT_DECAY=0.0005
IMAGE_SIZE=640
TRAIN_SPLIT=0.70
VAL_SPLIT=0.20
TEST_SPLIT=0.10
SAVE_EVERY=5

# Utiliser les poids pré-entraînés COCO (true recommandé)
PRETRAINED=true

# Seuil de confiance pour les prédictions
SCORE_THRESHOLD=0.5

# =============================================================================
# SORTIE
# =============================================================================

OUTPUT_DIR=./output
EVALUATION_DIR=./evaluation
PREDICTIONS_DIR=./predictions

# Chemin vers un modèle existant (pour evaluate.py et inference.py)
# Laisser vide pour auto-détection
MODEL_PATH=./runs/detect/train/fasterrcnn_20260301_190542/best_model.pth
